# Orakle Backend Environment Variables

# Security
SECRET_KEY=your-secure-secret-key
DEBUG=False
ALLOWED_HOSTS=your-render-domain.com,localhost,127.0.0.1

# Database
DATABASE_URL=postgres://user:password@host:port/dbname

# External APIs
ETHERSCAN_API_KEY=your-etherscan-api-key
ETH_RPC_URL=your-ethereum-rpc-url
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# AI Configuration
GEMINI_API_KEY=your-gemini-api-key
PREFERRED_MODEL=gemma-4-26b-a4b-it

# CORS
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:3000
